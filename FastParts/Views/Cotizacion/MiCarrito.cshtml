@model FastParts.Models.MiCarritoViewModel
@using System.Globalization
@{
    ViewBag.Title = "Mi Carrito";
    var cr = new CultureInfo("es-CR");
}

<div class="container mt-4">
    <h2><i class="bi bi-cart3"></i> Mi Carrito</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Repuestos.Any() && !Model.Servicios.Any())
    {
        <div class="alert alert-warning">Tu carrito esta vacio.</div>
        <a class="btn btn-primary" href="@Url.Action("CatalogoRepuestos", "Cotizacion")">Ir al catalogo</a>
    }
    else
    {
        if (Model.Repuestos.Any())
        {
            <h4>Repuestos</h4>
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Codigo</th>
                            <th>Repuesto</th>
                            <th>Precio unitario</th>
                            <th style="width:180px;">Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Repuestos)
                        {
                            <tr>
                                <td>RP-@item.IdRepuesto.ToString("D5")</td>
                                <td>@item.Nombre @if (!string.IsNullOrWhiteSpace(item.Marca)) { <small class="text-muted">(@item.Marca)</small> }</td>
                                <td>@item.PrecioUnitario.ToString("C", cr)</td>
                                <td>
                                    <div style="display:flex; gap:6px; align-items:center;">
                                        @using (Html.BeginForm("DisminuirRepuesto", "Cotizacion", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idRepuesto" value="@item.IdRepuesto" />
                                            <button type="submit" class="btn btn-default btn-sm">-</button>
                                        }
                                        <strong>@item.Cantidad</strong>
                                        @using (Html.BeginForm("IncrementarRepuesto", "Cotizacion", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idRepuesto" value="@item.IdRepuesto" />
                                            <button type="submit" class="btn btn-default btn-sm">+</button>
                                        }
                                    </div>
                                </td>
                                <td>@item.Subtotal.ToString("C", cr)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        if (Model.Servicios.Any())
        {
            <h4>Servicios</h4>
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Servicio</th>
                            <th>Precio unitario</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Servicios)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td>@item.PrecioUnitario.ToString("C", cr)</td>
                                <td>@item.Cantidad</td>
                                <td>@item.Subtotal.ToString("C", cr)</td>
                                <td>
                                    @using (Html.BeginForm("EliminarServicio", "Cotizacion", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idServicio" value="@item.IdServicio" />
                                        <button type="submit" class="btn btn-danger btn-xs">Eliminar uno</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="well">
            <p><strong>Total repuestos:</strong> @Model.TotalRepuestos.ToString("C", cr)</p>
            <p><strong>Total servicios:</strong> @Model.TotalServicios.ToString("C", cr)</p>
            <h4><strong>Total general: @Model.Total.ToString("C", cr)</strong></h4>
        </div>

        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a class="btn btn-default" href="@Url.Action("CatalogoRepuestos", "Cotizacion")">Seguir comprando</a>
            @using (Html.BeginForm("SolicitarCotizacion", "Cotizacion", FormMethod.Post, new { style = "display:inline;" }))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Solicitar cotizacion</button>
            }
        </div>
    }
</div>
