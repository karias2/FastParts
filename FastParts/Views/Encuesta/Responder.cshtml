@model FastParts.Models.ResponderEncuestaViewModel
@{
    ViewBag.Title = "Responder Encuesta";
}

<div class="container mt-4">
    <h2 class="mb-4">Encuesta de satisfacción</h2>

    @using (Html.BeginForm("Responder", "Encuesta", FormMethod.Post, new { id = "formEncuesta" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.EncuestaId)
        @Html.HiddenFor(m => m.CitaId)

        <div class="card shadow-sm">
            <div class="card-body">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row mb-3">
                    <div class="col-md-4">
                        <strong>Fecha cita:</strong> @Model.FechaCita.ToString("dd/MM/yyyy HH:mm")
                    </div>
                    <div class="col-md-4">
                        <strong>Vehículo:</strong> @Model.Vehiculo
                    </div>
                    <div class="col-md-4">
                        <strong>Mecánico:</strong> @Model.NombreMecanico
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.CalificacionGeneral, new { @class = "form-label" })
                    @Html.DropDownListFor(m => m.CalificacionGeneral,
                             new SelectList(new[]
                             {
                            new { Value = "", Text = "Seleccione una calificación" },
                            new { Value = "1", Text = "1 - Muy mala" },
                            new { Value = "2", Text = "2 - Mala" },
                            new { Value = "3", Text = "3 - Regular" },
                            new { Value = "4", Text = "4 - Buena" },
                            new { Value = "5", Text = "5 - Excelente" }
                         }, "Value", "Text"),
                             new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.CalificacionGeneral, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.CalificacionMecanico, new { @class = "form-label" })
                    @Html.DropDownListFor(m => m.CalificacionMecanico,
                             new SelectList(new[]
                             {
                            new { Value = "", Text = "Seleccione una calificación" },
                            new { Value = "1", Text = "1 - Muy mala" },
                            new { Value = "2", Text = "2 - Mala" },
                            new { Value = "3", Text = "3 - Regular" },
                            new { Value = "4", Text = "4 - Buena" },
                            new { Value = "5", Text = "5 - Excelente" }
                         }, "Value", "Text"),
                             new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.CalificacionMecanico, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.RecomendariaTaller, new { @class = "form-label d-block" })
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.RecomendariaTaller, true, new { @class = "form-check-input", id = "recomiendaSi" })
                        <label class="form-check-label" for="recomiendaSi">Sí</label>
                    </div>
                    <div class="form-check form-check-inline">
                        @Html.RadioButtonFor(m => m.RecomendariaTaller, false, new { @class = "form-check-input", id = "recomiendaNo" })
                        <label class="form-check-label" for="recomiendaNo">No</label>
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Comentario, new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Comentario, 4, 60, new { @class = "form-control", placeholder = "Comentario opcional sobre su experiencia" })
                    @Html.ValidationMessageFor(m => m.Comentario, "", new { @class = "text-danger" })
                </div>

                <div class="d-flex justify-content-end">
                    <a href="@Url.Action("MisCitas", "Cita")" class="btn btn-secondary me-2">Cancelar</a>
                    <button type="submit" class="btn btn-primary" id="btnEnviarEncuesta">Enviar encuesta</button>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $("#btnEnviarEncuesta").on("click", function (e) {
            e.preventDefault();

            Swal.fire({
                title: '¿Enviar encuesta?',
                text: 'Tu respuesta quedará registrada.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, enviar',
                cancelButtonText: 'Cancelar'
            }).then(result => {
                if (result.isConfirmed) {
                    $("#formEncuesta").off("submit").submit();
                }
            });
        });
    </script>
}