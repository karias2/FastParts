@model IEnumerable<FastParts.Models.CitaListadoViewModel>
@{
    ViewBag.Title = "Cola de Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Cola de Citas Disponibles</h2>
        <a href="@Url.Action("MisCitasMecanico", "Cita")" class="btn btn-outline-primary">
            Ver mis citas asignadas
        </a>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <label for="filtroFechaCola" class="form-label">Filtrar por fecha</label>
            <input type="date" id="filtroFechaCola" class="form-control" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="button" id="btnHoyCola" class="btn btn-outline-secondary me-2">
                Hoy
            </button>
            <button type="button" id="btnLimpiarFechaCola" class="btn btn-outline-secondary">
                Ver todas
            </button>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle mb-0" id="tablaColaCitas">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Teléfono</th>
                            <th>Vehículo</th>
                            <th>Placa</th>
                            <th>Fecha Cita</th>
                            <th>Estado</th>
                            <th style="width: 140px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.NombreCliente</td>
                                <td>@item.TelefonoCliente</td>
                                <td>@item.Vehiculo</td>
                                <td>@item.Placa</td>
                                <td>@item.FechaCita.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Estado</td>
                                <td class="text-center text-nowrap">
                                    @using (Html.BeginForm("TomarCita", "Cita", FormMethod.Post, new { @class = "formTomarCita d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)
                                        <button type="submit" class="btn btn-sm btn-primary btnTomarCita">
                                            Tomar cita
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        $(function () {

            function fechaHoyIsoLocal() {
                var hoy = new Date();
                var yyyy = hoy.getFullYear();
                var mm = String(hoy.getMonth() + 1).padStart(2, '0');
                var dd = String(hoy.getDate()).padStart(2, '0');
                return yyyy + '-' + mm + '-' + dd;
            }

            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {

                if (settings.nTable.id !== 'tablaColaCitas') {
                    return true;
                }

                var fechaFiltro = $('#filtroFechaCola').val();
                if (!fechaFiltro) {
                    return true;
                }

                var fechaTexto = data[4] || '';
                if (!fechaTexto) return false;

                var soloFecha = fechaTexto.split(' ')[0];
                var partes = soloFecha.split('/');

                if (partes.length !== 3) {
                    return true;
                }

                var dia = partes[0];
                var mes = partes[1];
                var anio = partes[2];

                var fechaNormalizada = anio + '-' + mes + '-' + dia;

                return fechaNormalizada === fechaFiltro;
            });

            var hoyIso = fechaHoyIsoLocal();
            $('#filtroFechaCola').val(hoyIso);

            var tabla = $("#tablaColaCitas").DataTable({
                order: [[4, "asc"]],
                autoWidth: false,
                responsive: false,
                scrollX: true,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                columnDefs: [
                    { targets: 0, width: "18%" },
                    { targets: 1, width: "12%" },
                    { targets: 2, width: "18%" },
                    { targets: 3, width: "10%" },
                    { targets: 4, width: "16%" },
                    { targets: 5, width: "10%" },
                    { targets: 6, width: "16%", orderable: false, searchable: false }
                ]
            });

            tabla.draw();

            $('#filtroFechaCola').on('change', function () {
                tabla.draw();
            });

            $('#btnHoyCola').on('click', function () {
                $('#filtroFechaCola').val(fechaHoyIsoLocal());
                tabla.draw();
            });

            $('#btnLimpiarFechaCola').on('click', function () {
                $('#filtroFechaCola').val('');
                tabla.draw();
            });

            $(".btnTomarCita").on("click", function (e) {
                e.preventDefault();
                const form = $(this).closest("form");

                Swal.fire({
                    title: '¿Tomar esta cita?',
                    text: 'La cita quedará asignada en tu lista de citas.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, tomar cita',
                    cancelButtonText: 'Cancelar'
                }).then(result => {
                    if (result.isConfirmed) {
                        form.off("submit").submit();
                    }
                });
            });
        });
    </script>
}