@model IEnumerable<FastParts.Models.CitaListadoViewModel>
@{
    ViewBag.Title = "Mis Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Mis Citas</h2>
        <div>
            <a href="@Url.Action("CrearCliente", "Cita")" class="btn btn-primary">
                Agendar nueva cita
            </a>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-3 mb-2">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Total de citas</h6>
                    <h3 class="mb-0">@ViewBag.TotalCitas</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Pendientes</h6>
                    <h3 class="mb-0">@ViewBag.CitasPendientes</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Terminadas</h6>
                    <h3 class="mb-0">@ViewBag.CitasTerminadas</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-2">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-1">Próxima cita</h6>
                    <div class="fw-bold">
                        @(ViewBag.ProximaCita != null
                        ? ((FastParts.Models.CitaListadoViewModel)ViewBag.ProximaCita).FechaCita.ToString("dd/MM/yyyy HH:mm")
                        : "No aplica")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle mb-0" " id="tablaMisCitas">
                    <thead>
                        <tr>
                            <th>Fecha Cita</th>
                            <th>Vehículo</th>
                            <th>Placa</th>
                            <th>Estado</th>
                            <th>Mecánico</th>
                            <th style="width:280px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FechaCita.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Vehiculo</td>
                                <td>@item.Placa</td>
                                <td>@item.Estado</td>
                                <td>@item.NombreMecanico</td>
                                <td class="text-center text-nowrap">
                                    <a href="@Url.Action("DetalleCliente", "Cita", new { id = item.Id })"
                                       class="btn btn-sm btn-outline-info mb-1">
                                        Ver detalles
                                    </a>

                                    @if (item.PuedeCancelar)
                                    {
                                        using (Html.BeginForm("CancelarCliente", "Cita", new { id = item.Id }, FormMethod.Post, new { @class = "form-cancelar-cita d-inline" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger mb-1">
                                                Cancelar
                                            </button>
                                        }
                                    }

                                    @if (item.TieneEncuestaPendiente && item.EncuestaPendienteId.HasValue)
                                    {
                                        <a href="@Url.Action("Responder", "Encuesta", new { id = item.EncuestaPendienteId.Value })"
                                           class="btn btn-sm btn-outline-success mb-1">
                                            Responder encuesta
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $("#tablaMisCitas").DataTable({
                order: [[0, "desc"]],
                autoWidth: false,
                responsive: false,
                scrollX: true,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                columnDefs: [
                    { targets: 0, width: "18%" }, // Fecha
                    { targets: 1, width: "22%" }, // Vehículo
                    { targets: 2, width: "12%" }, // Placa
                    { targets: 3, width: "12%" }, // Estado
                    { targets: 4, width: "18%" }, // Mecánico
                    { targets: 5, width: "18%", orderable: false, searchable: false } // Acciones
                ]
            });

            $('.form-cancelar-cita').on('submit', function (e) {
                e.preventDefault();
                var form = this;

                Swal.fire({
                    title: '¿Cancelar cita?',
                    text: 'Esta acción eliminará la cita definitivamente.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, cancelar',
                    cancelButtonText: 'No'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            var mensajeCreada = '@TempData["CitaCreada"]';
            if (mensajeCreada) {
                Swal.fire('¡Cita creada!', mensajeCreada, 'success');
            }

            var mensajeOk = '@TempData["CitaCancelada"]';
            if (mensajeOk) {
                Swal.fire('Cita cancelada', mensajeOk, 'success');
            }

            var mensajeError = '@TempData["ErrorCancelarCita"]';
            if (mensajeError) {
                Swal.fire('No fue posible cancelar', mensajeError, 'error');
            }
        });
    </script>
}
