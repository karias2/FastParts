@model FastParts.Models.CrearCitaClienteViewModel
@{
    ViewBag.Title = "Crear Cita (Cliente)";
}

<div class="container mt-4">
    <h2 class="mb-4">Agendar Cita</h2>

    @using (Html.BeginForm("CrearCliente", "Cita", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", id = "formCrearCitaCliente" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.NombreCliente, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.NombreCliente, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.NombreCliente, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.TelefonoCliente, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.TelefonoCliente, new { @class = "form-control", placeholder = "8888-8888" })
                        @Html.ValidationMessageFor(m => m.TelefonoCliente, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Vehiculo, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Vehiculo, new { @class = "form-control", placeholder = "Ej: Toyota Corolla 2018" })
                        @Html.ValidationMessageFor(m => m.Vehiculo, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Placa, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Placa, new { @class = "form-control", placeholder = "ABC123" })
                        @Html.ValidationMessageFor(m => m.Placa, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.FechaCita, new { @class = "form-label" })
                        @Html.TextBoxFor(
                                 m => m.FechaCita,
                                 "{0:yyyy-MM-dd HH:mm}",
                                 new
                                 {
                                     @class = "form-control",
                                     id = "FechaCitaCliente",
                                     autocomplete = "off",
                                     placeholder = "Seleccione fecha y hora"
                                 })
                        @Html.ValidationMessageFor(m => m.FechaCita, "", new { @class = "text-danger" })

                        <small class="text-muted d-block mt-1">
                            Horario: Lun–Vie 8:00 AM - 6:00 PM, Sáb 8:00 AM - 12:00 PM, Dom cerrado.
                        </small>
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Motivo, new { @class = "form-label" })
                        @Html.TextAreaFor(m => m.Motivo, 4, 40, new { @class = "form-control", placeholder = "Detalle del motivo de la visita" })
                        @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <a href="@Url.Action("MisCitas", "Cita")" class="btn btn-secondary me-2">Cancelar</a>
                    <button type="submit" class="btn btn-primary" id="btnGuardarCitaCliente">Guardar Cita</button>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(function () {
            const input = document.getElementById("FechaCitaCliente");
            const form = document.getElementById("formCrearCitaCliente");
            const btn = document.getElementById("btnGuardarCitaCliente");

            if (!input || !form || !btn) return;

            let horasDisponiblesPorFecha = {};

            function pad(n) {
                return n.toString().padStart(2, "0");
            }

            function formatDateYmd(date) {
                return date.getFullYear() + "-" + pad(date.getMonth() + 1) + "-" + pad(date.getDate());
            }

            function formatTimeHm(date) {
                return pad(date.getHours()) + ":" + pad(date.getMinutes());
            }

            function getMinDate() {
                const now = new Date();
                now.setHours(now.getHours() + 1);
                now.setSeconds(0);
                now.setMilliseconds(0);

                const minutos = now.getMinutes();
                const redondeado = Math.ceil(minutos / 30) * 30;
                now.setMinutes(redondeado);

                return now;
            }

            function getHorarioDelDia(date) {
                const day = date.getDay();

                if (day === 0) {
                    return null;
                }

                if (day === 6) {
                    return { minTime: "08:00", maxTime: "12:00" };
                }

                return { minTime: "08:00", maxTime: "18:00" };
            }

            function cargarHorasDisponibles(fecha) {
                const fechaStr = formatDateYmd(fecha);

                return $.getJSON('@Url.Action("ObtenerHorasDisponibles", "Cita")', { fecha: fechaStr })
                    .done(function (data) {
                        horasDisponiblesPorFecha[fechaStr] = data || [];
                    })
                    .fail(function () {
                        horasDisponiblesPorFecha[fechaStr] = [];
                    });
            }

            const fp = flatpickr(input, {
                locale: "es",
                enableTime: true,
                dateFormat: "Y-m-d H:i",
                altInput: true,
                altFormat: "d/m/Y h:i K",
                time_24hr: false,
                minuteIncrement: 30,
                minDate: getMinDate(),
                disable: [
                    function (date) {
                        return date.getDay() === 0;
                    }
                ],
                onReady: function (selectedDates, dateStr, instance) {
                    const now = getMinDate();
                    const horario = getHorarioDelDia(now);

                    if (horario) {
                        instance.set("minTime", horario.minTime);
                        instance.set("maxTime", horario.maxTime);
                    }
                },
                onChange: function (selectedDates, dateStr, instance) {
                    if (!selectedDates || !selectedDates.length) return;

                    const selected = selectedDates[0];
                    const fechaStr = formatDateYmd(selected);
                    const horaStr = formatTimeHm(selected);
                    const horario = getHorarioDelDia(selected);

                    if (!horario) {
                        instance.clear();
                        Swal.fire("Taller cerrado", "No se pueden agendar citas los domingos.", "warning");
                        return;
                    }

                    instance.set("minTime", horario.minTime);
                    instance.set("maxTime", horario.maxTime);

                    cargarHorasDisponibles(selected).done(function () {
                        const disponibles = horasDisponiblesPorFecha[fechaStr] || [];

                        if (disponibles.length === 0) {
                            instance.clear();
                            Swal.fire("Sin cupo", "No hay horarios disponibles para esa fecha.", "warning");
                            return;
                        }

                        if (horaStr && disponibles.indexOf(horaStr) === -1) {
                            instance.clear();
                            Swal.fire("Horario no disponible", "Ese horario ya no está disponible. Selecciona otro.", "warning");
                        }
                    });
                }
            });

            btn.addEventListener("click", function (e) {
                e.preventDefault();

                if (!form.checkValidity()) {
                    form.submit();
                    return;
                }

                if (!input.value) {
                    Swal.fire("Campo requerido", "Debes seleccionar una fecha y hora para la cita.", "warning");
                    return;
                }

                Swal.fire({
                    title: '¿Confirmar cita?',
                    text: 'Se registrará la cita con los datos indicados.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, guardar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}